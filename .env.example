# Add your API key for the provider you want to use.
# Only one is required.

GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override provider (default: gemini)
# VIBE_AUDIT_PROVIDER=openai

# Optional: override model
# VIBE_AUDIT_MODEL=gpt-4o

# ─── Qure Integration ────────────────────────────────────────────────────────

# Path to Qure-generated tests (default: tests/qure)
# QURE_TEST_DIR=tests/qure

# Auto-detect Qure tests anywhere in the project (default: true)
# QURE_AUTO_DETECT=true

# Additional directories to scan for Qure tests (comma-separated)
# QURE_SCAN_DIRS=tests,e2e,test,__tests__,spec

# Extract rich metadata from Qure tests for better risk analysis (default: true)
# QURE_EXTRACT_METADATA=true

# Show coverage gap suggestions in the report (default: true)
# QURE_COVERAGE_GAPS=true

# Risk weight multiplier for Qure-recorded flows (default: 1.5)
# Higher = risks affecting recorded user flows are scored more severely
# QURE_RISK_WEIGHT=1.5

# ─── Static Analysis ─────────────────────────────────────────────────────────

# Optional: disable static analysis
# VIBE_AUDIT_TSC=false
# VIBE_AUDIT_ESLINT=false
